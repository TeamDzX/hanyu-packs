      {
        "id": "xiaolongbao",
        "name": "Soup Dumplings",
        "hanzi": "小笼包",
        "pinyin": "xiǎolóngbāo",
        "categories": [
          "dumpling",
          "pork",
          "steamed"
        ],
        "time": "2 hrs",
        "difficulty": "Hard",
        "image": "https://raw.githubusercontent.com/TeamDzX/hanyu-packs/main/images/food/xiaolongbao.jpg",
        "description": "Shanghai's famous xiaolongbao — delicate steamed parcels that burst with hot soup. The trick is folding gelled stock into the filling, which melts as they steam.",
        "ingredients": [
          "300g minced pork",
          "1 cup pork-stock aspic (chilled until set), diced",
          "1 tbsp ginger + 2 spring onions, minced",
          "2 tbsp soy sauce, 1 tbsp Shaoxing wine, 1 tsp sugar",
          "Thin round dumpling wrappers",
          "Black vinegar & ginger slivers, to serve"
        ],
        "steps": [
          "Mix the pork, seasonings, ginger and spring onion, then fold through the diced aspic.",
          "Place a spoonful on each wrapper and pleat into a sealed purse with a twisted top.",
          "Steam over high heat for 8 minutes until the filling is cooked and soupy.",
          "Lift carefully, dip in black vinegar with ginger, and bite gently to sip the soup first."
        ],
